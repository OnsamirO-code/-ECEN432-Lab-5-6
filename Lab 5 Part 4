def run_sweep_redundant(config):
    """Run SNDR sweep for the pipelined ADC WITH redundancy."""
    sndr_arr = np.zeros(len(config['param_range']))
    for i, val in enumerate(config['param_range']):
        sub_p, ra_p = config['apply'](val)
        d_out, _ = pipelined_adc_redundant(v_in_tone,
                                           sub_adc_params=sub_p,
                                           ra_params=ra_p)
        v_out = d_out * LSB_total + LSB_total / 2
        v_out_ac = v_out - np.mean(v_out)
        sndr_arr[i], _, _ = compute_sndr_enob(v_out_ac, signal_bin=C)
    return sndr_arr


def run_sweep_no_redundancy(config):
    """Run SNDR sweep for the pipelined ADC WITHOUT redundancy."""
    lsb_nr = VFS / (2**6)  # 6-bit total
    sndr_arr = np.zeros(len(config['param_range']))

    for i, val in enumerate(config['param_range']):
        sub_p, ra_p = config['apply'](val)
        # Adjust sub_adc_params for 3 comparators (no redundancy)
        sub_p_nr = []
        for sp in sub_p:
            sp_nr = {}
            for key, v in sp.items():
                if isinstance(v, np.ndarray) and len(v) == N_comp:
                    # Truncate to 3 comparators
                    sp_nr[key] = v[:N_comp_nr]
                else:
                    sp_nr[key] = v
            sub_p_nr.append(sp_nr)

        d_out = pipelined_adc_no_redundancy(v_in_tone,
                                            sub_adc_params=sub_p_nr,
                                            ra_params=ra_p)
        v_out = d_out * lsb_nr + lsb_nr / 2
        v_out_ac = v_out - np.mean(v_out)
        sndr_arr[i], _, _ = compute_sndr_enob(v_out_ac, signal_bin=C)
    return sndr_arr


