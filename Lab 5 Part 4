# ─────────────────────────────────────────────
# Global Parameters
# ─────────────────────────────────────────────
VFS      = 1.0        # Full-scale voltage (V)
N_comp   = 6          # Comparators per stage (2.5-bit with redundancy)
N_stages = 3          # Number of pipeline stages
LSB_sub  = VFS / 8    # Sub-ADC LSB (3-bit output per stage)
G        = 4          # Interstage gain = 2^2
M        = 2048       # FFT length
C        = 113        # Bin-aligned frequency index
Fs       = 1e9        # Sampling frequency
Fin      = Fs * C / M # Input frequency
L        = M

# Time and frequency vectors
t = np.arange(1, L + 1) / Fs
