# Reference levels for 2.5-bit sub-ADC (with redundancy)
V_ref_redundant = np.array([VFS * (i + 1) / 8 for i in range(N_comp)])

# Reference levels for 2-bit sub-ADC (without redundancy): 3 comparators
N_comp_nr = 3
V_ref_no_redundancy = np.array([VFS * (i + 1) / 4 for i in range(N_comp_nr)])


# ═════════════════════════════════════════════
# HELPER FUNCTIONS
# ═════════════════════════════════════════════

def compute_psd_linear(x):
    """One-sided linear PSD (V^2/Hz)."""
    X   = np.fft.fft(x)[:L // 2 + 1]
    psd = (1 / (Fs * L)) * np.abs(X)**2
    psd[1:-1] *= 2
    return psd


def compute_sndr_enob(x_out, signal_bin):
    """Compute SNDR and ENOB from FFT."""
    psd = compute_psd_linear(x_out)
    sig_power   = np.sum(psd[max(0, signal_bin - 1):signal_bin + 2])
    total_power = np.sum(psd[1:])
    nd_power    = total_power - sig_power
    if nd_power <= 0:
        nd_power = 1e-30
    sndr = 10 * np.log10(sig_power / nd_power)
    enob = (sndr - 1.76) / 6.02
    return sndr, enob, psd


# ─────────────────────────────────────────────
# Sub-ADC (with and without redundancy)
# ─────────────────────────────────────────────

def sub_adc(v_in, v_ref, n_comp, offsets=None, gain_errs=None, alpha2s=None, alpha3s=None):
    """
    General sub-ADC: thermometer code → digital code.
    Works for both 2.5-bit (6 comp, redundant) and 2-bit (3 comp, no redundancy).
    """
    if offsets   is None: offsets   = np.zeros(n_comp)
    if gain_errs is None: gain_errs = np.zeros(n_comp)
    if alpha2s   is None: alpha2s   = np.zeros(n_comp)
    if alpha3s   is None: alpha3s   = np.zeros(n_comp)

    n = len(v_in)
    therm = np.zeros((n_comp, n))
    for i in range(n_comp):
        v_eff = v_ref[i] + offsets[i] + gain_errs[i] * v_in + alpha2s[i] * v_in**2 + alpha3s[i] * v_in**3
        therm[i] = (v_in > v_eff).astype(int)

    max_code = 2**3 - 1 if n_comp == 6 else 2**2 - 1  # 7 for redundant, 3 for non-redundant
    d_out = np.minimum(np.sum(therm, axis=0), max_code).astype(int)
    return d_out


def sub_dac(d_code, lsb):
    """DAC reconstruction: midpoint of quantization bin."""
    return d_code * lsb + lsb / 2


def residue_amplifier(v_in, epsilon=0.0, v_offset=0.0, alpha2=0.0, alpha3=0.0):
    """Non-ideal residue amplifier: V_out = (1+ε)·G·V_in + V_offset + α2·V_in² + α3·V_in³"""
    return (1 + epsilon) * G * v_in + v_offset + alpha2 * v_in**2 + alpha3 * v_in**3


# ─────────────────────────────────────────────
# Pipeline Stage
# ─────────────────────────────────────────────

def pipeline_stage(v_in, v_ref, n_comp, lsb,
                   sub_adc_params=None, ra_params=None):
    """
    Single pipeline stage:
      1. Sub-ADC quantizes v_in → digital code
      2. DAC reconstructs → v_dac
      3. Residue = RA( v_in - v_dac )

    Returns: (digital_code, residue_out)
    """
    if sub_adc_params is None:
        sub_adc_params = {}
    if ra_params is None:
        ra_params = {}

    d_code = sub_adc(v_in, v_ref, n_comp, **sub_adc_params)
    v_dac  = sub_dac(d_code, lsb)
    v_diff = v_in - v_dac
    v_res  = residue_amplifier(v_diff, **ra_params)
    return d_code, v_res


# ─────────────────────────────────────────────
# Full 3-Stage Pipeline (with redundancy)
# ─────────────────────────────────────────────

def pipelined_adc_redundant(v_in,
                            sub_adc_params=None,   # list of 3 dicts
                            ra_params=None):       # list of 3 dicts (last stage RA not used)
    """
    3-stage pipelined ADC, 2.5 bits/stage with 1-bit redundancy.
    Each stage outputs 3 raw bits; digital correction combines them.

    With redundancy:
      - Each stage: 2 effective bits + 1 redundant bit
      - Total raw bits: 3 × 3 = 9
      - After digital correction: 3 × 2 + 1 = 7 bits
    """
    if sub_adc_params is None:
        sub_adc_params = [{}, {}, {}]
    if ra_params is None:
        ra_params = [{}, {}, {}]

    n = len(v_in)
    d_codes = []

    # Stage 1
    d1, v_res1 = pipeline_stage(v_in, V_ref_redundant, N_comp, LSB_sub,
                                sub_adc_params[0], ra_params[0])
    # Clip residue to [0, VFS] for next stage input
    v_res1 = np.clip(v_res1, 0, VFS)
    d_codes.append(d1)

    # Stage 2
    d2, v_res2 = pipeline_stage(v_res1, V_ref_redundant, N_comp, LSB_sub,
                                sub_adc_params[1], ra_params[1])
    v_res2 = np.clip(v_res2, 0, VFS)
    d_codes.append(d2)

    # Stage 3 (last stage — no RA needed, just sub-ADC)
    d3 = sub_adc(v_res2, V_ref_redundant, N_comp, **sub_adc_params[2])
    d_codes.append(d3)

    # Digital error correction with redundancy:
    # Each stage produces 3 bits but only 2 are "effective".
    # Shift stage 1 by 4 bits, stage 2 by 2 bits, add stage 3.
    # Then truncate to 7 bits. The overlap (redundancy) corrects
    # sub-ADC offset errors via simple addition and carry.
    d_combined = d_codes[0] * 16 + d_codes[1] * 4 + d_codes[2]
    # Cap at 7-bit max (127)
    d_combined = np.clip(d_combined, 0, 127)

    return d_combined, d_codes


def pipelined_adc_no_redundancy(v_in,
                                sub_adc_params=None,
                                ra_params=None):
    """
    3-stage pipelined ADC, 2 bits/stage, NO redundancy.
    Each stage: 2-bit sub-ADC (3 comparators), gain = 4.
    Total: 3 × 2 = 6 bits (64 levels).
    """
    if sub_adc_params is None:
        sub_adc_params = [{}, {}, {}]
    if ra_params is None:
        ra_params = [{}, {}, {}]

    lsb_nr = VFS / 4   # 2-bit LSB

    # Stage 1
    d1 = sub_adc(v_in, V_ref_no_redundancy, N_comp_nr, **sub_adc_params[0])
    v_dac1 = sub_dac(d1, lsb_nr)
    v_res1 = residue_amplifier(v_in - v_dac1, **ra_params[0])
    v_res1 = np.clip(v_res1, 0, VFS)

    # Stage 2
    d2 = sub_adc(v_res1, V_ref_no_redundancy, N_comp_nr, **sub_adc_params[1])
    v_dac2 = sub_dac(d2, lsb_nr)
    v_res2 = residue_amplifier(v_res1 - v_dac2, **ra_params[1])
    v_res2 = np.clip(v_res2, 0, VFS)

    # Stage 3
    d3 = sub_adc(v_res2, V_ref_no_redundancy, N_comp_nr, **sub_adc_params[2])

    # No error correction — just concatenate: 2+2+2 = 6 bits
    d_combined = d1 * 16 + d2 * 4 + d3
    d_combined = np.clip(d_combined, 0, 63)

    return d_combined


