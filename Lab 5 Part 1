# ═════════════════════════════════════════════
# PART (f): Single-Tone PSD, SNDR, ENOB
# ═════════════════════════════════════════════
# Input: full-scale single tone (bin-aligned)
A_sig = VFS / 2       # Amplitude: signal swings 0 to VFS → centered at VFS/2
v_in_tone = A_sig * np.cos(2 * np.pi * Fin * t) + VFS / 2  # DC offset to [0, VFS]

# Quantize through ideal flash ADC
d_out_tone, _ = flash_adc_25bit(v_in_tone)
v_out_tone = digital_to_analog(d_out_tone)

# Remove DC for PSD
v_out_ac = v_out_tone - np.mean(v_out_tone)
v_in_ac  = v_in_tone  - np.mean(v_in_tone)

# PSD and SNDR
sndr, enob, psd_out = compute_sndr_enob(v_out_ac, signal_bin=C)
psd_db = 10 * np.log10(psd_out + 1e-30)

