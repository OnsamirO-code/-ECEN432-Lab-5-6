import numpy as np
import matplotlib.pyplot as plt

# ─────────────────────────────────────────────
# Global Parameters
# ─────────────────────────────────────────────
VFS      = 1.0        # Full-scale voltage (V)
N_bits   = 3          # 2.5-bit → 3-bit digital output (6 comparators, 1-bit redundancy)
N_comp   = 6          # Number of comparators for 2.5-bit flash (2^2.5 - 1 ≈ 6 with redundancy)
M        = 2048       # FFT length / number of samples
C        = 113        # Frequency bin index (prime → avoids spectral leakage)
Fs       = 1e9        # Sampling frequency (Hz)
Fin      = Fs * C / M # Bin-aligned input frequency (Hz)
L        = M          # Signal length = FFT length

# ─────────────────────────────────────────────
# 2.5-bit Flash ADC Reference Levels (with redundancy)
# ─────────────────────────────────────────────
# A standard 2-bit flash has 3 comparators at VFS/4, 2*VFS/4, 3*VFS/4.
# A 2.5-bit flash with 1-bit redundancy uses 6 comparators.
# The redundancy overlaps decision levels so that comparator offsets
# can be corrected by digital post-processing.
#
# Reference levels are spaced at VFS/8 intervals:
#   VFS/8, 2*VFS/8, 3*VFS/8, 4*VFS/8, 5*VFS/8, 6*VFS/8
# i.e. 0.125, 0.25, 0.375, 0.5, 0.625, 0.75

V_ref = np.array([VFS * (i + 1) / 8 for i in range(N_comp)])
# V_ref = [0.125, 0.25, 0.375, 0.5, 0.625, 0.75]

# Ideal LSB for 3-bit output (8 levels over VFS)
LSB = VFS / 8

# Time and frequency vectors
t = np.arange(1, L + 1) / Fs
f = np.linspace(0, Fs / 2, L // 2 + 1)


# ═════════════════════════════════════════════
# HELPER FUNCTIONS
# ═════════════════════════════════════════════

def comparator(v_in, v_ref, offset=0.0, gain_err=0.0, alpha2=0.0, alpha3=0.0):
    """
    Non-ideal comparator model.
    Effective threshold = v_ref + offset + gain_err * v_in + alpha2 * v_in^2 + alpha3 * v_in^3
    Returns 1 if v_in > effective threshold, else 0.
    """
    v_eff = v_ref + offset + gain_err * v_in + alpha2 * v_in**2 + alpha3 * v_in**3
    return (v_in > v_eff).astype(int)


def thermometer_to_digital(therm):
    """
    Convert thermometer code (6 comparators) to 3-bit digital output.
    Digital output = number of 1s in thermometer code (sum), capped at 7.
    """
    return np.minimum(np.sum(therm, axis=0), 7).astype(int)


def flash_adc_25bit(v_in, offsets=None, gain_errs=None, alpha2s=None, alpha3s=None):
    """
    2.5-bit flash ADC with redundancy.
    Returns 3-bit digital output codes (0 to 7).
    """
    if offsets   is None: offsets   = np.zeros(N_comp)
    if gain_errs is None: gain_errs = np.zeros(N_comp)
    if alpha2s   is None: alpha2s   = np.zeros(N_comp)
    if alpha3s   is None: alpha3s   = np.zeros(N_comp)

    # Generate thermometer code from all 6 comparators
    therm = np.zeros((N_comp, len(v_in)))
    for i in range(N_comp):
        therm[i] = comparator(v_in, V_ref[i],
                              offset=offsets[i],
                              gain_err=gain_errs[i],
                              alpha2=alpha2s[i],
                              alpha3=alpha3s[i])

    # Convert thermometer → digital
    d_out = thermometer_to_digital(therm)
    return d_out, therm


def digital_to_analog(d_out):
    """Convert digital code back to analog (for error computation)."""
    return d_out * LSB + LSB / 2   # midpoint of each quantization bin


def compute_psd_linear(x):
    """One-sided linear PSD (V^2/Hz) — same normalization as Lab 4."""
    X   = np.fft.fft(x)[:L // 2 + 1]
    psd = (1 / (Fs * L)) * np.abs(X)**2
    psd[1:-1] *= 2   # double all bins except DC and Nyquist
    return psd


def compute_sndr_enob(x_out, signal_bin):
    """
    Compute SNDR and ENOB from FFT.
    signal_bin: index of the fundamental tone in the one-sided spectrum.
    """
    psd = compute_psd_linear(x_out)
    # Signal power: fundamental bin (±1 bin for leakage)
    sig_power = np.sum(psd[max(0, signal_bin - 1):signal_bin + 2])
    # Total power (exclude DC bin 0)
    total_power = np.sum(psd[1:])
    # Noise + distortion
    nd_power = total_power - sig_power
    if nd_power <= 0:
        nd_power = 1e-30
    sndr = 10 * np.log10(sig_power / nd_power)
    enob = (sndr - 1.76) / 6.02
    return sndr, enob, psd


