# ═════════════════════════════════════════════
# PART (e): DNL and INL (Offset Errors Only)
# ═════════════════════════════════════════════
# Use a fine ramp to compute transition points
N_fine = 100000
v_fine = np.linspace(0, VFS, N_fine)

# With offset errors only (gain_err = alpha2 = alpha3 = 0)
np.random.seed(42)
offsets_only = np.random.uniform(-offset_range, offset_range, N_comp)

d_out_offset, _ = flash_adc_25bit(v_fine, offsets=offsets_only)

# Find transition voltages (where digital code changes)
transitions_ideal  = V_ref   # Ideal transitions at reference levels
transitions_actual = []
for code in range(1, 8):
    idx = np.where(d_out_offset >= code)[0]
    if len(idx) > 0:
        transitions_actual.append(v_fine[idx[0]])
    else:
        transitions_actual.append(VFS)  # never reached

transitions_actual = np.array(transitions_actual)

# Actual step widths
step_widths = np.diff(np.concatenate(([0], transitions_actual, [VFS])))
ideal_step  = LSB

# DNL = (actual step width - ideal step width) / ideal step width
dnl = (step_widths - ideal_step) / ideal_step

# INL = cumulative sum of DNL
inl = np.cumsum(dnl)

print("=" * 60)
print("PART (e): DNL and INL (Offset Errors Only)")
print("=" * 60)
print(f"  Offset errors used: {offsets_only * 1000} mV")
print(f"  Transition voltages (ideal):  {transitions_ideal}")
print(f"  Transition voltages (actual): {transitions_actual}")
print(f"  DNL (LSB): {dnl}")
print(f"  INL (LSB): {inl}")
print(f"  Max |DNL| = {np.max(np.abs(dnl)):.4f} LSB")
print(f"  Max |INL| = {np.max(np.abs(inl)):.4f} LSB")
print()

