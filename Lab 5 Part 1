# ═════════════════════════════════════════════
# PART (g): Monte Carlo — 50 Iterations
# ═════════════════════════════════════════════
N_mc = 50
sndr_mc = np.zeros(N_mc)
enob_mc = np.zeros(N_mc)
dnl_max_mc = np.zeros(N_mc)
inl_max_mc = np.zeros(N_mc)

for mc in range(N_mc):
    np.random.seed(mc + 1000)  # distinct seeds from part (d)

    # Random non-idealities for all comparators
    offsets_mc   = np.random.uniform(-offset_range,   offset_range,   N_comp)
    gain_errs_mc = np.random.uniform(-gain_err_range, gain_err_range, N_comp)
    alpha2s_mc   = np.random.uniform(-alpha2_range,   alpha2_range,   N_comp)
    alpha3s_mc   = np.random.uniform(-alpha3_range,   alpha3_range,   N_comp)

    # --- SNDR / ENOB (single-tone) ---
    d_out_mc, _ = flash_adc_25bit(v_in_tone, offsets_mc, gain_errs_mc, alpha2s_mc, alpha3s_mc)
    v_out_mc = digital_to_analog(d_out_mc)
    v_out_mc_ac = v_out_mc - np.mean(v_out_mc)
    sndr_mc[mc], enob_mc[mc], _ = compute_sndr_enob(v_out_mc_ac, signal_bin=C)

    # --- DNL / INL (fine ramp, offset errors only for consistency with part e) ---
    d_ramp_mc, _ = flash_adc_25bit(v_fine, offsets=offsets_mc)
    trans_mc = []
    for code in range(1, 8):
        idx = np.where(d_ramp_mc >= code)[0]
        if len(idx) > 0:
            trans_mc.append(v_fine[idx[0]])
        else:
            trans_mc.append(VFS)
    trans_mc = np.array(trans_mc)
    sw_mc = np.diff(np.concatenate(([0], trans_mc, [VFS])))
    dnl_mc_vals = (sw_mc - ideal_step) / ideal_step
    inl_mc_vals = np.cumsum(dnl_mc_vals)
    dnl_max_mc[mc] = np.max(np.abs(dnl_mc_vals))
    inl_max_mc[mc] = np.max(np.abs(inl_mc_vals))

# --- Safe histogram helper ---
def safe_hist(ax, data, max_bins=15, **kwargs):
    """Histogram that handles zero-spread or near-zero-spread data."""
    data_range = np.ptp(data)
    if data_range == 0:
        # All values identical — create a single bar manually
        center = data[0]
        width = max(abs(center) * 0.1, 0.01)  # 10% of value or 0.01
        ax.bar(center, len(data), width=width, **kwargs)
    else:
        n_unique = len(np.unique(np.round(data, 10)))
        n_bins = max(1, min(max_bins, n_unique))
        ax.hist(data, bins=n_bins, **kwargs)

