# PART (d): Non-ideal Comparators — 100 Random Trials
# ═════════════════════════════════════════════
# Error ranges (reasonable for demonstration)
offset_range  = 0.05    # ±50 mV offset
gain_err_range = 0.02   # ±2% gain error
alpha2_range  = 0.1     # 2nd order nonlinearity coefficient
alpha3_range  = 0.1     # 3rd order nonlinearity coefficient

