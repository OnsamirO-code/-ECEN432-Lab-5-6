#!/usr/bin/env python3
"""
ECEN 432 – LAB 6, Part 1
4-stage Pipelined ADC (2b/stage, no redundancy)
Calibration automation with 5 algorithms:
  1) Direct Iterative (coordinate-descent on knobs)
  2) LMS (gradient-descent / Least-Mean-Squared)
  3) CPS + Parallel Thompson Sampling
  4) Reinforcement Learning (Q-learning on knobs)
  5) Agentic AI (multi-agent cooperative calibration)

Conventions: bin-aligned FFT at bin C=113, np.random.seed,
             one-sided PSD via 1/(Fs*L), plt.show()
"""

import numpy as np
import matplotlib.pyplot as plt

# ============================================================
# Global parameters
# ============================================================
np.random.seed(42)

N_STAGES   = 4
BITS_STAGE = 2
N_BITS     = N_STAGES * BITS_STAGE  # 8-bit overall

Vref       = 1.0
Fs         = 1e6
L          = 4096
C          = 113
Fin        = C * Fs / L
A_in       = Vref * 0.95

L_CAL      = 512       # shorter signal for calibration speed
C_CAL      = 29        # coherent bin for calibration signal

N_MC       = 100
N_ITER_CAL = 100
N_MC_CAL   = 10

OFFSET_STD = 0.030
GAIN_STD   = 0.030

# ============================================================
# Vectorized Pipeline ADC model (2b/stage, no redundancy)
# ============================================================
class PipelinedADC:
    def __init__(self, Vref=1.0, n_stages=4):
        self.Vref = Vref
        self.n_stages = n_stages
        self.bits_per_stage = 2
        self.ideal_gain = 4
        self.ideal_thresholds = np.array([-Vref/2, 0.0, Vref/2])
        self.comp_offsets = [np.zeros(3) for _ in range(n_stages)]
        self.gain_errors  = np.zeros(n_stages)
        self.offset_knobs = [np.zeros(3) for _ in range(n_stages)]
        self.gain_knobs   = np.zeros(n_stages)

    def set_impairments(self, offset_std, gain_std):
        for s in range(self.n_stages):
            self.comp_offsets[s] = np.random.randn(3) * offset_std
        self.gain_errors = np.random.randn(self.n_stages) * gain_std

    def reset_knobs(self):
        self.offset_knobs = [np.zeros(3) for _ in range(self.n_stages)]
        self.gain_knobs   = np.zeros(self.n_stages)

    def convert(self, x):
        v = x.copy()
        all_codes = np.zeros((self.n_stages, len(x)), dtype=int)
        for s in range(self.n_stages):
            th = self.ideal_thresholds + self.comp_offsets[s] + self.offset_knobs[s]
            code = ((v > th[0]).astype(int) + (v > th[1]).astype(int)
                    + (v > th[2]).astype(int))
            all_codes[s] = code
            vdac = (code - 1.5) * (self.Vref / 2)
            if s < self.n_stages - 1:
                gain = self.ideal_gain * (1.0 + self.gain_errors[s] + self.gain_knobs[s])
                v = gain * (v - vdac)
        digital = np.zeros(len(x), dtype=int)
        for s in range(self.n_stages):
            digital += all_codes[s] * (self.ideal_gain ** (self.n_stages - 1 - s))
        return digital

    def convert_to_analog(self, x):
        codes = self.convert(x)
        n_levels = self.ideal_gain ** self.n_stages
        return (codes / (n_levels - 1)) * 2 * self.Vref - self.Vref

    def get_all_knobs(self):
        knobs = []
        for s in range(self.n_stages):
            knobs.extend(self.offset_knobs[s].tolist())
        knobs.extend(self.gain_knobs.tolist())
        return np.array(knobs)

    def set_all_knobs(self, kv):
        idx = 0
        for s in range(self.n_stages):
            self.offset_knobs[s] = kv[idx:idx+3].copy()
            idx += 3
        self.gain_knobs = kv[idx:idx+self.n_stages].copy()

    @property
    def n_knobs(self):
        return 3 * self.n_stages + self.n_stages  # 16

# ============================================================
# Helpers
# ============================================================
def gen_sin(L, A, C, Fs):
    n = np.arange(L)
    return A * np.sin(2 * np.pi * C * n / L)

def compute_sndr(x, C, L, n_sig_bins=7):
    """Compute SNDR using Hanning window, summing signal power over
    n_sig_bins centered on bin C to account for window spreading."""
    w = np.hanning(L)
    X = np.fft.fft(x * w)
    Pxx = np.abs(X[:L//2])**2
    half = n_sig_bins // 2
    lo = max(1, C - half)
    hi = min(L//2, C + half + 1)
    sig_power = np.sum(Pxx[lo:hi])
    nd_power = np.sum(Pxx[1:L//2]) - sig_power
    if nd_power <= 0:
        return 80.0
    return 10 * np.log10(sig_power / nd_power)

def eval_mse(adc, x):
    y = adc.convert_to_analog(x)
    return np.mean((y - x)**2)

def eval_sndr(adc, x, C, L):
    y = adc.convert_to_analog(x)
    return compute_sndr(y, C, L)

x_test = gen_sin(L, A_in, C, Fs)
x_cal  = gen_sin(L_CAL, A_in, C_CAL, Fs)

